# Required — service role key bypasses RLS; keep it server-side only, never in the web app.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional (defaults shown)
PORT=8080
AUDIO_BUCKET=audio
THUMBNAIL_BUCKET=thumbnails
AUDIO_BITRATE=128k
HLS_TIME=6
POLL_INTERVAL_MS=4000
MAX_ATTEMPTS=3
# true = serve cached HLS via public bucket URLs (v1 default); false = signed URLs
PUBLIC_AUDIO=true
